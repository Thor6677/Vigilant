{
  "name": "@vigilant/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vigilant design system — expressive brutalist EVE dashboard components",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "fonts"],
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./index.css": "./dist/index.css"
  },
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "demo": "vite demo --open"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.0",
    "jsdom": "^26.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^3.0.0"
  }
}
