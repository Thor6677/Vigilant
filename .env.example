# EVE Online SSO
EVE_CLIENT_ID=your_production_client_id
EVE_CLIENT_SECRET=your_production_client_secret
EVE_CALLBACK_URL=https://yourdomain.com/auth/callback

# App
SECRET_KEY=change_this_to_a_long_random_string
DATABASE_URL=sqlite:///./vigilant.db
DEBUG=false

# EVE character id of the owner/admin. On a fresh deploy with no admin yet,
# ONLY the account that owns this character is auto-promoted to admin at
# startup. Leave unset and no one is auto-promoted (fail closed) — the app
# will log a reminder. Set this to your own character id before first launch.
# ADMIN_CHARACTER_ID=

# For local dev override these in .env
# EVE_CLIENT_ID=your_dev_client_id
# EVE_CLIENT_SECRET=your_dev_client_secret
# EVE_CALLBACK_URL=http://localhost:8000/auth/callback

# Discord webhooks (both optional, both no-op when unset — and DELIBERATELY
# separate from each other, don't alias them):
# DISCORD_WEBHOOK is the shared ops/backfill-progress ping (see everef_ingest.py).
# DISCORD_WEBHOOK_URL is the user-facing alert relay (structure attacks, fuel
# alerts, etc — see app/notify/discord.py); gated per-type by DISCORD_ALERT_TYPES.
# DISCORD_WEBHOOK=
# DISCORD_WEBHOOK_URL=
# DISCORD_ALERT_TYPES=structure_attack,structure_fuel
